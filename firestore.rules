rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required, immutable)
    //   - name: string (required, 1-50 chars)
    //   - age: number (required, 18-120)
    //   - location: string (required, 1-100 chars)
    //   - bio: string (optional, < 500 chars)
    //   - image: string (optional, valid URL)
    //   - interests: list (optional, < 20 items)
    //   - isVerified: bool (admin only update)
    //   - isPremium: bool (admin only update)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: matches
    // Document ID: {matchId}
    // Fields:
    //   - users: list (required, size 2, contains UIDs)
    //   - timestamp: timestamp (required)
    //
    // Collection: chats/{chatId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - senderId: string (required, must match auth.uid)
    //   - receiverId: string (required)
    //   - text: string (required, 1-1000 chars)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "siphes9812@gmail.com" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isNotRestricted() {
      return isAuthenticated() && 
        request.auth.token.email_verified == true &&
        (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) != true &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) != true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'age', 'gender', 'location', 'images', 'createdAt']) &&
             data.keys().hasOnly([
               'id', 'uid', 'name', 'displayName', 'email', 'age', 'gender', 'lookingFor', 
               'location', 'bio', 'height', 'education', 'zodiac', 'images', 'interests', 
               'isVerified', 'verificationSelfie', 'verificationStatus', 'isPremium', 'isOnline', 'lastSeen', 'createdAt', 'role', 
               'isBanned', 'isBlocked', 'smoking', 'drinking', 'relationshipGoal', 
               'hobbies', 'latitude', 'longitude', 'preferredAgeMin', 'preferredAgeMax', 
               'preferredDistance', 'preferredEducation', 'adminRights', 'pushNotificationsEnabled'
             ]) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.age is number && data.age >= 18 && data.age <= 120 &&
             data.gender is string &&
             (!('lookingFor' in data) || (data.lookingFor is string && data.lookingFor.size() <= 50)) &&
             data.location is string && data.location.size() > 0 && data.location.size() <= 200 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('height' in data) || (data.height is number || data.height is string)) &&
             (!('education' in data) || (data.education is string && data.education.size() <= 100)) &&
             (!('zodiac' in data) || (data.zodiac is string && data.zodiac.size() <= 50)) &&
             data.images is list && data.images.size() <= 15 &&
             (!('interests' in data) || (data.interests is list && data.interests.size() <= 50)) &&
             (!('hobbies' in data) || (data.hobbies is list && data.hobbies.size() <= 50)) &&
             (!('isOnline' in data) || data.isOnline is bool) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('verificationSelfie' in data) || data.verificationSelfie is string) &&
             (!('verificationStatus' in data) || data.verificationStatus in ['none', 'pending', 'approved', 'rejected']) &&
             (!('isPremium' in data) || data.isPremium is bool) &&
             (!('lastSeen' in data) || data.lastSeen is timestamp) &&
             (!('role' in data) || data.role in ['user', 'admin']) &&
             (!('isBanned' in data) || data.isBanned is bool) &&
             (!('isBlocked' in data) || data.isBlocked is bool) &&
             (!('latitude' in data) || data.latitude == null || data.latitude is number) &&
             (!('longitude' in data) || data.longitude == null || data.longitude is number) &&
             (!('preferredAgeMin' in data) || data.preferredAgeMin is number) &&
             (!('preferredAgeMax' in data) || data.preferredAgeMax is number) &&
             (!('preferredDistance' in data) || data.preferredDistance is number) &&
             (!('preferredEducation' in data) || data.preferredEducation is list) &&
             (!('pushNotificationsEnabled' in data) || data.pushNotificationsEnabled is bool) &&
             (!('smoking' in data) || data.smoking is string) &&
             (!('drinking' in data) || data.drinking is string) &&
             (!('relationshipGoal' in data) || data.relationshipGoal is string) &&
             (!('adminRights' in data) || data.adminRights is map) &&
             data.createdAt is timestamp;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['users', 'timestamp']) &&
             data.users is list && data.users.size() == 2 &&
             request.auth.uid in data.users &&
             data.timestamp is timestamp &&
             (!('typing' in data) || data.typing is map);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'text', 'timestamp']) &&
             data.senderId == request.auth.uid &&
             data.receiverId is string &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.timestamp is timestamp;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'fromUserId', 'title', 'message', 'read', 'createdAt']) &&
             data.userId is string &&
             (data.type in ['match', 'message', 'like', 'system']) &&
             (data.fromUserId == request.auth.uid || (isAdmin() && data.fromUserId == 'admin')) &&
             data.title is string && data.title.size() <= 100 &&
             data.message is string && data.message.size() <= 1000 &&
             data.read is bool &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == request.auth.uid &&
                      (!('role' in request.resource.data) || request.resource.data.role == 'user') &&
                      (!('isBanned' in request.resource.data) || request.resource.data.isBanned == false) &&
                      (!('isVerified' in request.resource.data) || request.resource.data.isVerified == false) && 
                      (!('isPremium' in request.resource.data) || request.resource.data.isPremium == false);
      allow update: if (isOwner(userId) || isAdmin()) && 
                      (isAdmin() || (isValidUser(request.resource.data) &&
                       request.resource.data.uid == request.auth.uid &&
                       (request.resource.data.createdAt == resource.data.createdAt || request.resource.data.createdAt == request.time) &&
                       (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) &&
                       (!('isBanned' in request.resource.data) || request.resource.data.isBanned == resource.data.isBanned) &&
                       (!('isBlocked' in request.resource.data) || request.resource.data.isBlocked == resource.data.isBlocked) &&
                       (!('isVerified' in request.resource.data) || request.resource.data.isVerified == resource.data.isVerified) &&
                       (!('verificationStatus' in request.resource.data) || 
                         request.resource.data.verificationStatus == resource.data.get('verificationStatus', 'none') || 
                         request.resource.data.verificationStatus == 'pending') &&
                       (!('isPremium' in request.resource.data) || request.resource.data.isPremium == resource.data.isPremium)));
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isAdmin() || (isNotRestricted() && request.auth.uid in resource.data.users);
      allow create: if isNotRestricted() && isValidMatch(request.resource.data);
      allow update: if isAdmin() || (isNotRestricted() && request.auth.uid in resource.data.users);
      allow delete: if isAdmin() || (isNotRestricted() && request.auth.uid in resource.data.users);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAdmin() || (isNotRestricted() && (
        exists(/databases/$(database)/documents/matches/$(chatId)) &&
        request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.users
      ));
      allow create: if isNotRestricted() && isValidMessage(request.resource.data) && (
        exists(/databases/$(database)/documents/matches/$(chatId)) &&
        request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.users
      );
      allow delete: if isAdmin() || (isNotRestricted() && resource.data.senderId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || (isNotRestricted() && isOwner(resource.data.userId));
      allow create: if (isNotRestricted() && isValidNotification(request.resource.data)) || isAdmin();
      allow update: if isAdmin() || (isNotRestricted() && isOwner(resource.data.userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
      allow delete: if isAdmin() || (isNotRestricted() && isOwner(resource.data.userId));
    }

    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // System logs
      allow update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && 
                      request.resource.data.reporterId == request.auth.uid &&
                      request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /likes/{likeId} {
      allow read: if isAuthenticated() && (isAdmin() || likeId.split('_').hasAny([request.auth.uid]));
      allow create: if isNotRestricted() && 
                      likeId.split('_')[0] == request.auth.uid &&
                      request.resource.data.fromUserId == request.auth.uid;
      allow delete: if isAuthenticated() && likeId.split('_')[0] == request.auth.uid;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
