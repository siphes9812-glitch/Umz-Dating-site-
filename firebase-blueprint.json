{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Display name" },
        "age": { "type": "integer", "description": "User age" },
        "gender": { "type": "string", "enum": ["male", "female", "other"], "description": "User gender" },
        "location": { "type": "string", "description": "User location" },
        "education": { "type": "string", "description": "User educational background" },
        "latitude": { "type": "number", "description": "User latitude" },
        "longitude": { "type": "number", "description": "User longitude" },
        "preferredAgeMin": { "type": "integer", "description": "Minimum preferred age" },
        "preferredAgeMax": { "type": "integer", "description": "Maximum preferred age" },
        "preferredDistance": { "type": "integer", "description": "Maximum preferred distance in km" },
        "preferredEducation": { "type": "array", "items": { "type": "string" }, "description": "Preferred educational backgrounds" },
        "bio": { "type": "string", "description": "User biography" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Gallery of profile images (min 2)" },
        "interests": { "type": "array", "items": { "type": "string" }, "description": "List of interests" },
        "isVerified": { "type": "boolean", "description": "Whether the user is verified" },
        "isPremium": { "type": "boolean", "description": "Whether the user has premium status" },
        "isOnline": { "type": "boolean", "description": "Current online status" },
        "lastSeen": { "type": "string", "format": "date-time", "description": "Last activity timestamp" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "name", "age", "gender", "location", "images"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "UID of the sender" },
        "receiverId": { "type": "string", "description": "UID of the receiver" },
        "text": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["senderId", "receiverId", "text", "timestamp"]
    },
    "Match": {
      "title": "Match",
      "description": "A match between two users",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" }, "description": "Array of two UIDs" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the match occurred" }
      },
      "required": ["users", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the recipient" },
        "type": { "type": "string", "enum": ["match", "message", "like"], "description": "Type of notification" },
        "fromUserId": { "type": "string", "description": "UID of the sender/trigger" },
        "text": { "type": "string", "description": "Notification message" },
        "read": { "type": "boolean", "description": "Whether the notification has been read" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the notification was created" }
      },
      "required": ["userId", "type", "fromUserId", "text", "read", "timestamp"]
    },
    "Report": {
      "title": "Report",
      "description": "User report for a profile",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string", "description": "UID of the reporter" },
        "reportedId": { "type": "string", "description": "UID of the reported user" },
        "reason": { "type": "string", "description": "Reason for reporting" },
        "message": { "type": "string", "description": "Optional message" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"], "description": "Status of the report" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the report was created" }
      },
      "required": ["reporterId", "reportedId", "reason", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Matches between users"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "User reports"
    }
  }
}
